# ========================================
# 마이홈 서버 환경변수 설정 (로컬 개발용)
# ========================================
# 사용법: cp .env.example .env 후 값 수정
# 주의: .env 파일은 절대 Git에 커밋하지 마세요!

# ----------------------------------------
# 서버 실행 모드 (NODE_ENV)
# ----------------------------------------
#
# [개발 모드] NODE_ENV=development  ← 현재 설정
#   - nodemon + ts-node로 서버 실행 (cd server && npm run dev)
#   - 클라이언트는 Vite 개발 서버로 별도 실행 (cd client && npm run dev)
#   - Vite가 /api, /uploads 요청을 Express로 프록시 처리
#
# [프로덕션 모드] NODE_ENV=production
#   - 빌드된 JS로 서버 실행 (cd server && npm start)
#   - Express가 클라이언트 빌드 파일(client/dist)을 직접 서빙
#   - 별도 정적 서버(serve, http-server 등) 불필요
#   - 다른 IP에서 이미지 업로드 후 404 문제 해결됨
#
#   ★ 프로덕션 실행 순서:
#     1) cd client && npm run build
#     2) cd server && npm run build
#     3) NODE_ENV=production 으로 변경 후 저장
#     4) cd server && npm start
#     5) http://서버IP:4000 으로 접속
#
NODE_ENV=development
PORT=4000

# ----------------------------------------
# 데이터베이스 설정
# DB_TYPE: sqlite | mysql | mariadb | postgresql | postgres
# ----------------------------------------
DB_TYPE=sqlite
# SQLite 전용 (DB_TYPE=sqlite일 때만 사용)
DB_STORAGE=./database.sqlite

# MySQL / MariaDB / PostgreSQL 전용 (DB_TYPE이 sqlite가 아닐 때 필수)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=myhome
# DB_PASSWORD=secure-db-password
# DB_NAME=myhome
# DB_SSL=false

# MySQL/MariaDB 루트 비밀번호 (Docker 환경에서 사용)
# DB_ROOT_PASSWORD=secure-root-password

# ----------------------------------------
# JWT 인증 (반드시 변경하세요!)
# ----------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-32-chars

# ----------------------------------------
# 관리자 계정
# ----------------------------------------
# 초기 admin 계정 비밀번호 (설정 후 반드시 변경하세요!)
ADMIN_DEFAULT_PASSWORD=admin

# ----------------------------------------
# CORS 설정 (세 가지 방법 중 하나를 선택)
# ----------------------------------------

# [방법 1] 사내 인트라넷 전용 — 모든 IP 허용 (인터넷 미노출 환경 권장, 가장 간단)
# 20.x.x.x, 192.168.x.x 등 회사 어떤 IP에서든 접속 가능
# CORS_ALLOW_ALL=true

# [방법 2] 회사 IP 대역을 정규식 패턴으로 허용
# 예: 20.x.x.x 대역 → ^https?:\/\/20\.\d+\.\d+\.\d+(:\d+)?$
# 예: 172.20.x.x 대역 → ^https?:\/\/172\.20\.\d+\.\d+(:\d+)?$
# CORS_IP_PATTERN=^https?:\/\/20\.\d+\.\d+\.\d+(:\d+)?$

# [방법 3] 특정 IP/도메인만 화이트리스트 지정 (쉼표 구분)
# CORS_ORIGINS=http://20.1.2.3:8080,https://intranet.company.com

# ----------------------------------------
# 보안 설정
# ----------------------------------------
# 관리자 API 접근 허용 IP 목록 (쉼표 구분, 미설정 시 전체 허용)
# ALLOWED_ADMIN_IPS=127.0.0.1,::1

# 쿠키 Secure 플래그 (HTTPS 환경에서만 true로 설정)
# HTTP만 사용하는 인트라넷 환경: false (기본값)
# HTTPS를 사용하는 외부 배포 환경: true
COOKIE_SECURE=false

# ----------------------------------------
# 로그 보존 기간 설정
# ----------------------------------------
# 보안 로그 보존 일수 (기본값: 90)
SECURITY_LOG_RETENTION_DAYS=90

# 에러 로그 보존 일수 (기본값: 30)
ERROR_LOG_RETENTION_DAYS=30
